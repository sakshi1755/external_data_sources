# Unit-level data files — gated behind microdata.gov.in login, can't be
# redistributed. See README → Fetch the data. .Nesstar archives are too big
# for git anyway.
raw/data*/*.txt
raw/data*/*.TXT
raw/data*/*.zip
raw/data*/*.Nesstar
raw/213*/
raw/data*/Guide*.pdf
raw/data*/*.exe

# Built outputs from raw data — regenerable via scripts/parse_plfs_data.py.
# Calendar-year CSVs especially are too large to commit (CY2025 cperv1.csv
# alone is ~700MB).
clean/annual_2023_24/hhv1.csv
clean/annual_2023_24/hhrv.csv
clean/annual_2023_24/perv1.csv
clean/annual_2023_24/perrv.csv
clean/calendar_2024/chhv1.csv
clean/calendar_2024/cperv1.csv
clean/calendar_2025/chhv1.csv
clean/calendar_2025/cperv1.csv

# Local scratch / OS detritus
.DS_Store
*.html
catalog_page.html
getmicro.html
__pycache__/
*.pyc

# Cached PDF text (regenerable from PDF via pdftotext)
raw/docs/*.txt
raw/external/*.txt

# Pre-existing per-release folders in this working dir (other releases — exclude
# until we explicitly decide to bring them in. Calendar-year releases use a
# different layout from the annual release this repo documents.)
PLFS 2022/
PLFS 2023/
PLFS_2025/

# Local Claude harness state — not for the repo
.claude/
